# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://invs_user:invs_password@localhost:5432/invs_db?schema=public"

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
# Login con Google
# ─────────────────────────────────────────
# Client ID de un OAuth Client de Google Cloud Console (tipo "Web
# application" alcanza para verificar idTokens tanto de web como de
# mobile con Expo) — no es secreto, se usa también del lado del cliente.
GOOGLE_CLIENT_ID=

# ─────────────────────────────────────────
# QR / Ticket signing
# ─────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_HMAC_SECRET=CHANGE_ME_QR_SECRET_32_CHARS

# ─────────────────────────────────────────
# Streaming Provider
# ─────────────────────────────────────────
# Opciones disponibles: mux | youtube
# Para cambiar de proveedor: solo cambiar esta línea + completar las vars del nuevo proveedor
STREAMING_PROVIDER=mux

# ─────────────────────────────────────────
# Mux (Streaming) — activo cuando STREAMING_PROVIDER=mux
# ─────────────────────────────────────────
# Obtener en: dashboard.mux.com → Settings → API Access Tokens
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_secret
# Tiempo en segundos para el signed playback URL
MUX_SIGNED_URL_TTL=3600

# ─────────────────────────────────────────
# YouTube (Streaming) — activo cuando STREAMING_PROVIDER=youtube
# ─────────────────────────────────────────
# Obtener en: console.cloud.google.com → APIs → YouTube Data API v3
# YOUTUBE_CLIENT_ID=your_google_client_id
# YOUTUBE_CLIENT_SECRET=your_google_client_secret
# YOUTUBE_REFRESH_TOKEN=oauth2_refresh_token_del_canal_invs
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,https://admin.invs.app

# ─────────────────────────────────────────
# URL base del frontend web (para links de mail: aceptar transferencia, etc.)
# ─────────────────────────────────────────
WEB_BASE_URL=http://localhost:5174

# ─────────────────────────────────────────
# Órdenes: TTL de reserva de cupo antes de liberarlo automáticamente
# ─────────────────────────────────────────
CARD_ORDER_TTL_MINUTES=15
TRANSFER_ORDER_TTL_HOURS=72

# ─────────────────────────────────────────
# Transferencia bancaria (se muestran en el checkout) — PLACEHOLDER,
# reemplazar por los datos reales de Panda antes de ir a producción
# ─────────────────────────────────────────
BANK_TRANSFER_BANK_NAME="Banco Ejemplo"
BANK_TRANSFER_HOLDER="Panda Estudios SRL"
BANK_TRANSFER_CBU=0000000000000000000000
BANK_TRANSFER_ALIAS=PANDA.EVENTOS.INVS
BANK_TRANSFER_CUIT=00-00000000-0

# ─────────────────────────────────────────
# Pagos con tarjeta — Openpay Argentina (BBVA)
# ─────────────────────────────────────────
PAYMENT_PROVIDER=openpay
# Obtener en el dashboard de Openpay Argentina (docs.ecommercebbva.com)
OPENPAY_MERCHANT_ID=your_openpay_merchant_id
OPENPAY_PRIVATE_KEY=your_openpay_private_key
# Esta también se expone al frontend (VITE_OPENPAY_PUBLIC_KEY / EXPO_PUBLIC_OPENPAY_PUBLIC_KEY)
OPENPAY_PUBLIC_KEY=your_openpay_public_key
# false = sandbox (sand-api.ecommercebbva.com), true = producción (api.ecommercebbva.com)
OPENPAY_PRODUCTION=false

# ─────────────────────────────────────────
# Mail
# ─────────────────────────────────────────
# Opciones disponibles: smtp | console (console solo loguea, no envía de verdad)
MAIL_PROVIDER=console
FROM_EMAIL=no-reply@invs.app
FROM_NAME=INVS

# SMTP — activo cuando MAIL_PROVIDER=smtp (sirve con SendGrid, Resend, Mailtrap, Gmail, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
